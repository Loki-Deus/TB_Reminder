DISCORD_TOKEN=
TW_CHANNEL_ID=
OFFICER_ID=
MEMBER_ROLE_ID=
# Comma-separated list of Discord user IDs allowed to run TB commands (besides admins)
MANAGER_IDS=
# Directory where stats.json is stored (defaults to current directory if not set)
DATA_DIR=
# Timezone for /start_tb_timer input parsing (defaults to Europe/Vienna)
# Use IANA timezone names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
BOT_TIMEZONE=Europe/Vienna
